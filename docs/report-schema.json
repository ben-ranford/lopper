{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/lopper/report.schema.json",
  "title": "Lopper Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "repoPath", "dependencies"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.1.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "repoPath": { "type": "string" },
    "scope": { "$ref": "#/$defs/scopeMetadata" },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/dependencyReport" }
    },
    "usageUncertainty": { "$ref": "#/$defs/usageUncertainty" },
    "summary": { "$ref": "#/$defs/summary" },
    "languageBreakdown": {
      "type": "array",
      "items": { "$ref": "#/$defs/languageSummary" }
    },
    "cache": { "$ref": "#/$defs/cacheMetadata" },
    "effectiveThresholds": { "$ref": "#/$defs/effectiveThresholds" },
    "effectivePolicy": { "$ref": "#/$defs/effectivePolicy" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "wasteIncreasePercent": { "type": "number" },
    "baselineComparison": { "$ref": "#/$defs/baselineComparison" }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependencyCount",
        "usedExportsCount",
        "totalExportsCount",
        "usedPercent",
        "knownLicenseCount",
        "unknownLicenseCount",
        "deniedLicenseCount"
      ],
      "properties": {
        "dependencyCount": { "type": "integer", "minimum": 0 },
        "usedExportsCount": { "type": "integer", "minimum": 0 },
        "totalExportsCount": { "type": "integer", "minimum": 0 },
        "usedPercent": { "type": "number", "minimum": 0 },
        "knownLicenseCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Dependencies with known non-denied license metadata."
        },
        "unknownLicenseCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Dependencies with unknown non-denied license metadata."
        },
        "deniedLicenseCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Dependencies denied by license policy; mutually exclusive with knownLicenseCount and unknownLicenseCount."
        },
        "reachability": { "$ref": "#/$defs/reachabilityRollup" },
        "vulnerabilities": { "$ref": "#/$defs/vulnerabilitySummary" }
      }
    },
    "scopeMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string" },
        "packages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "usageUncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmedImportUses", "uncertainImportUses"],
      "properties": {
        "confirmedImportUses": { "type": "integer", "minimum": 0 },
        "uncertainImportUses": { "type": "integer", "minimum": 0 },
        "samples": {
          "type": "array",
          "items": { "$ref": "#/$defs/location" }
        }
      }
    },
    "languageSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "dependencyCount", "usedExportsCount", "totalExportsCount", "usedPercent"],
      "properties": {
        "language": { "type": "string" },
        "dependencyCount": { "type": "integer", "minimum": 0 },
        "usedExportsCount": { "type": "integer", "minimum": 0 },
        "totalExportsCount": { "type": "integer", "minimum": 0 },
        "usedPercent": { "type": "number", "minimum": 0 }
      }
    },
    "effectiveThresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failOnIncreasePercent",
        "lowConfidenceWarningPercent",
        "minUsagePercentForRecommendations",
        "maxUncertainImportCount"
      ],
      "properties": {
        "failOnIncreasePercent": { "type": "integer", "minimum": -1 },
        "lowConfidenceWarningPercent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "minUsagePercentForRecommendations": { "type": "integer", "minimum": 0, "maximum": 100 },
        "maxUncertainImportCount": { "type": "integer", "minimum": -1 },
        "reachableVulnerabilityPriority": {
          "type": "string",
          "enum": ["off", "low", "medium", "high", "critical"]
        }
      }
    },
    "cacheMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "hits", "misses", "writes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string" },
        "readOnly": { "type": "boolean" },
        "hits": { "type": "integer", "minimum": 0 },
        "misses": { "type": "integer", "minimum": 0 },
        "writes": { "type": "integer", "minimum": 0 },
        "invalidations": {
          "type": "array",
          "items": { "$ref": "#/$defs/cacheInvalidation" }
        }
      }
    },
    "cacheInvalidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "reason"],
      "properties": {
        "key": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "effectivePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["thresholds", "removalCandidateWeights", "license"],
      "properties": {
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mergeTrace": {
          "type": "array",
          "items": { "$ref": "#/$defs/policyMergeTrace" }
        },
        "thresholds": { "$ref": "#/$defs/effectiveThresholds" },
        "removalCandidateWeights": { "$ref": "#/$defs/removalCandidateWeights" },
        "license": { "$ref": "#/$defs/licensePolicy" },
        "vulnerabilities": { "$ref": "#/$defs/vulnerabilityPolicy" }
      }
    },
    "licensePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["failOnDenied", "includeRegistryProvenance"],
      "properties": {
        "deny": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failOnDenied": { "type": "boolean" },
        "includeRegistryProvenance": { "type": "boolean" }
      }
    },
    "dependencyReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "usedExportsCount", "totalExportsCount", "usedPercent", "estimatedUnusedBytes"],
      "properties": {
        "language": { "type": "string" },
        "name": { "type": "string" },
        "usedExportsCount": { "type": "integer", "minimum": 0 },
        "totalExportsCount": { "type": "integer", "minimum": 0 },
        "usedPercent": { "type": "number", "minimum": 0 },
        "estimatedUnusedBytes": { "type": "integer" },
        "topUsedSymbols": {
          "type": "array",
          "items": { "$ref": "#/$defs/symbolUsage" }
        },
        "usedImports": {
          "type": "array",
          "items": { "$ref": "#/$defs/importUse" }
        },
        "unusedImports": {
          "type": "array",
          "items": { "$ref": "#/$defs/importUse" }
        },
        "unusedExports": {
          "type": "array",
          "items": { "$ref": "#/$defs/symbolRef" }
        },
        "riskCues": {
          "type": "array",
          "items": { "$ref": "#/$defs/riskCue" }
        },
        "recommendations": {
          "type": "array",
          "items": { "$ref": "#/$defs/recommendation" }
        },
        "codemod": { "$ref": "#/$defs/codemodReport" },
        "runtimeUsage": { "$ref": "#/$defs/runtimeUsage" },
        "reachabilityConfidence": { "$ref": "#/$defs/reachabilityConfidence" },
        "removalCandidate": { "$ref": "#/$defs/removalCandidate" },
        "license": { "$ref": "#/$defs/dependencyLicense" },
        "provenance": { "$ref": "#/$defs/dependencyProvenance" },
        "vulnerabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/vulnerabilityFinding" }
        }
      }
    },
    "vulnerabilityFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["advisoryId", "package", "severity", "source", "priority", "priorityScore", "reachable"],
      "properties": {
        "advisoryId": { "type": "string" },
        "package": { "type": "string" },
        "severity": { "type": "string" },
        "fixedVersion": { "type": "string" },
        "source": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "priorityScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "reachable": { "type": "boolean" },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "vulnerabilityPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "advisorySourcePath": { "type": "string" },
        "reachablePriorityThreshold": {
          "type": "string",
          "enum": ["off", "low", "medium", "high", "critical"]
        }
      }
    },
    "vulnerabilitySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totalFindings", "reachableFindings"],
      "properties": {
        "totalFindings": { "type": "integer", "minimum": 0 },
        "reachableFindings": { "type": "integer", "minimum": 0 },
        "highestSeverity": { "type": "string" },
        "highestPriority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "bySeverity": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "byPriority": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "dependencyLicense": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "spdx": { "type": "string" },
        "raw": { "type": "string" },
        "source": { "type": "string" },
        "confidence": { "type": "string" },
        "unknown": { "type": "boolean" },
        "denied": { "type": "boolean" },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "dependencyProvenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "confidence": { "type": "string" },
        "signals": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "policyMergeTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "source"],
      "properties": {
        "field": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "symbolUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "count"],
      "properties": {
        "name": { "type": "string" },
        "module": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "importUse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "module"],
      "properties": {
        "name": { "type": "string" },
        "module": { "type": "string" },
        "locations": {
          "type": "array",
          "items": { "$ref": "#/$defs/location" }
        },
        "provenance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidenceScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidenceReasonCodes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "symbolRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "module"],
      "properties": {
        "name": { "type": "string" },
        "module": { "type": "string" },
        "confidenceScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidenceReasonCodes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line", "column"],
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      }
    },
    "riskCue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "message": { "type": "string" },
        "confidenceScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidenceReasonCodes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "priority", "message"],
      "properties": {
        "code": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "message": { "type": "string" },
        "rationale": { "type": "string" },
        "confidenceScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidenceReasonCodes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "codemodReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["suggest-only", "apply"] },
        "suggestions": {
          "type": "array",
          "items": { "$ref": "#/$defs/codemodSuggestion" }
        },
        "skips": {
          "type": "array",
          "items": { "$ref": "#/$defs/codemodSkip" }
        },
        "apply": {
          "$ref": "#/$defs/codemodApplyReport"
        }
      }
    },
    "codemodSuggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line", "importName", "fromModule", "toModule", "original", "replacement", "patch"],
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "importName": { "type": "string" },
        "fromModule": { "type": "string" },
        "toModule": { "type": "string" },
        "original": { "type": "string" },
        "replacement": { "type": "string" },
        "patch": { "type": "string" }
      }
    },
    "codemodSkip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line", "importName", "module", "reasonCode", "message"],
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "importName": { "type": "string" },
        "module": { "type": "string" },
        "reasonCode": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "codemodApplyReport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "appliedFiles": { "type": "integer", "minimum": 0 },
        "appliedPatches": { "type": "integer", "minimum": 0 },
        "skippedFiles": { "type": "integer", "minimum": 0 },
        "skippedPatches": { "type": "integer", "minimum": 0 },
        "failedFiles": { "type": "integer", "minimum": 0 },
        "failedPatches": { "type": "integer", "minimum": 0 },
        "backupPath": { "type": "string" },
        "results": {
          "type": "array",
          "items": { "$ref": "#/$defs/codemodApplyResult" }
        }
      }
    },
    "codemodApplyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "status", "patchCount"],
      "properties": {
        "file": { "type": "string" },
        "status": { "type": "string", "enum": ["applied", "skipped", "failed"] },
        "patchCount": { "type": "integer", "minimum": 0 },
        "message": { "type": "string" }
      }
    },
    "runtimeUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["loadCount"],
      "properties": {
        "loadCount": { "type": "integer", "minimum": 0 },
        "correlation": {
          "type": "string",
          "enum": ["static-only", "runtime-only", "overlap"]
        },
        "runtimeOnly": { "type": "boolean" },
        "modules": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleUsage" }
        },
        "parentModules": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleUsage" }
        },
        "entrypoints": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleUsage" }
        },
        "topSymbols": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeSymbolUsage" }
        }
      }
    },
    "runtimeModuleUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "count"],
      "properties": {
        "module": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "runtimeSymbolUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol", "count"],
      "properties": {
        "symbol": { "type": "string" },
        "module": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "reachabilityConfidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "score"],
      "properties": {
        "model": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "summary": { "type": "string" },
        "rationaleCodes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "signals": {
          "type": "array",
          "items": { "$ref": "#/$defs/reachabilitySignal" }
        }
      }
    },
    "reachabilitySignal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "score", "weight", "contribution"],
      "properties": {
        "code": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "contribution": { "type": "number", "minimum": 0, "maximum": 100 },
        "rationale": { "type": "string" }
      }
    },
    "reachabilityRollup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "averageScore", "lowestScore", "highestScore"],
      "properties": {
        "model": { "type": "string" },
        "averageScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "lowestScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "highestScore": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "removalCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "usage", "impact", "confidence", "weights"],
      "properties": {
        "score": { "type": "number", "minimum": 0 },
        "usage": { "type": "number", "minimum": 0, "maximum": 100 },
        "impact": { "type": "number", "minimum": 0, "maximum": 100 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "weights": { "$ref": "#/$defs/removalCandidateWeights" },
        "rationale": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "removalCandidateWeights": {
      "type": "object",
      "additionalProperties": false,
      "required": ["usage", "impact", "confidence"],
      "properties": {
        "usage": { "type": "number", "minimum": 0 },
        "impact": { "type": "number", "minimum": 0 },
        "confidence": { "type": "number", "minimum": 0 }
      }
    },
    "baselineComparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summaryDelta"],
      "properties": {
        "baselineKey": { "type": "string" },
        "currentKey": { "type": "string" },
        "summaryDelta": { "$ref": "#/$defs/summaryDelta" },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyDelta" }
        },
        "regressions": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyDelta" }
        },
        "progressions": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyDelta" }
        },
        "runtimeRegressions": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyDelta" }
        },
        "runtimeImprovements": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyDelta" }
        },
        "added": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyDelta" }
        },
        "removed": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyDelta" }
        },
        "newDeniedLicenses": {
          "type": "array",
          "items": { "$ref": "#/$defs/deniedLicenseDelta" }
        },
        "newReachableVulnerabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/vulnerabilityDelta" }
        },
        "unchangedRows": { "type": "integer", "minimum": 0 }
      }
    },
    "summaryDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dependencyCountDelta",
        "usedExportsCountDelta",
        "totalExportsCountDelta",
        "usedPercentDelta",
        "wastePercentDelta",
        "unusedBytesDelta",
        "knownLicenseCountDelta",
        "unknownLicenseCountDelta",
        "deniedLicenseCountDelta"
      ],
      "properties": {
        "dependencyCountDelta": { "type": "integer" },
        "usedExportsCountDelta": { "type": "integer" },
        "totalExportsCountDelta": { "type": "integer" },
        "usedPercentDelta": { "type": "number" },
        "wastePercentDelta": { "type": "number" },
        "unusedBytesDelta": { "type": "integer" },
        "knownLicenseCountDelta": { "type": "integer" },
        "unknownLicenseCountDelta": { "type": "integer" },
        "deniedLicenseCountDelta": { "type": "integer" },
        "reachableVulnerabilityCountDelta": { "type": "integer" }
      }
    },
    "dependencyDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name",
        "usedExportsCountDelta",
        "totalExportsCountDelta",
        "usedPercentDelta",
        "estimatedUnusedBytesDelta",
        "wastePercentDelta"
      ],
      "properties": {
        "kind": { "type": "string", "enum": ["added", "removed", "changed"] },
        "language": { "type": "string" },
        "name": { "type": "string" },
        "usedExportsCountDelta": { "type": "integer" },
        "totalExportsCountDelta": { "type": "integer" },
        "usedPercentDelta": { "type": "number" },
        "estimatedUnusedBytesDelta": { "type": "integer" },
        "wastePercentDelta": { "type": "number" },
        "runtimeDelta": { "$ref": "#/$defs/runtimeDelta" },
        "deniedIntroduced": { "type": "boolean" },
        "reachableVulnerabilityCountDelta": { "type": "integer" },
        "reachableVulnerabilitiesIntroduced": { "type": "boolean" }
      }
    },
    "runtimeDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["comparable", "baselinePresent", "currentPresent"],
      "properties": {
        "comparable": { "type": "boolean" },
        "baselinePresent": { "type": "boolean" },
        "currentPresent": { "type": "boolean" },
        "baselineLoadCount": { "type": "integer", "minimum": 0 },
        "currentLoadCount": { "type": "integer", "minimum": 0 },
        "loadCountDelta": { "type": "integer" },
        "baselineCorrelation": {
          "type": "string",
          "enum": ["static-only", "runtime-only", "overlap"]
        },
        "currentCorrelation": {
          "type": "string",
          "enum": ["static-only", "runtime-only", "overlap"]
        },
        "changeTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "load-count",
              "new-runtime-loads",
              "removed-runtime-loads",
              "correlation",
              "runtime-only-regression",
              "runtime-only-improvement",
              "modules",
              "parent-modules",
              "entrypoints"
            ]
          }
        },
        "newRuntimeLoads": { "type": "boolean" },
        "removedRuntimeLoads": { "type": "boolean" },
        "runtimeOnlyRegression": { "type": "boolean" },
        "runtimeOnlyImprovement": { "type": "boolean" },
        "modulesAdded": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleDelta" }
        },
        "modulesRemoved": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleDelta" }
        },
        "modulesChanged": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleDelta" }
        },
        "parentModulesAdded": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleDelta" }
        },
        "parentModulesRemoved": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleDelta" }
        },
        "parentModulesChanged": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleDelta" }
        },
        "entrypointsAdded": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleDelta" }
        },
        "entrypointsRemoved": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleDelta" }
        },
        "entrypointsChanged": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModuleDelta" }
        }
      }
    },
    "runtimeModuleDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "baselineCount", "currentCount", "countDelta"],
      "properties": {
        "module": { "type": "string" },
        "baselineCount": { "type": "integer", "minimum": 0 },
        "currentCount": { "type": "integer", "minimum": 0 },
        "countDelta": { "type": "integer" }
      }
    },
    "deniedLicenseDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "language": { "type": "string" },
        "name": { "type": "string" },
        "spdx": { "type": "string" }
      }
    },
    "vulnerabilityDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "advisoryId", "package", "severity", "source", "priority", "priorityScore"],
      "properties": {
        "language": { "type": "string" },
        "name": { "type": "string" },
        "advisoryId": { "type": "string" },
        "package": { "type": "string" },
        "severity": { "type": "string" },
        "fixedVersion": { "type": "string" },
        "source": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "priorityScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
