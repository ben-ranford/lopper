{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "go",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "draft": true,
  "force-tag-creation": true,
  "packages": {
    ".": {
      "release-type": "go",
      "changelog-path": "extensions/vscode-lopper/CHANGELOG.md",
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes"
        },
        {
          "type": "bug",
          "section": "Bug Fixes"
        },
        {
          "type": "perf",
          "section": "Performance Improvements"
        },
        {
          "type": "docs",
          "section": "Documentation"
        },
        {
          "type": "refactor",
          "section": "Code Refactoring"
        },
        {
          "type": "revert",
          "section": "Reverts"
        }
      ],
      "extra-files": [
        {
          "type": "json",
          "path": "extensions/vscode-lopper/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "extensions/vscode-lopper/package-lock.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "extensions/vscode-lopper/package-lock.json",
          "jsonpath": "$['packages'][''].version"
        }
      ]
    }
  }
}
