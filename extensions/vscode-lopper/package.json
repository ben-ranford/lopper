{
  "name": "vscode-lopper",
  "displayName": "Lopper",
  "description": "VS Code diagnostics, dependency explorer details, baseline workflows, runtime trace analysis, and safe JS/TS quick fixes across Lopper adapters, including Kotlin Android and PowerShell.",
  "version": "1.5.4",
  "publisher": "BenRanford",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ben-ranford/lopper.git",
    "directory": "extensions/vscode-lopper"
  },
  "homepage": "https://github.com/ben-ranford/lopper",
  "bugs": {
    "url": "https://github.com/ben-ranford/lopper/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Lopper does not execute workspace-local binaries until the workspace is trusted."
    }
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "lopper",
    "dependencies",
    "imports",
    "diagnostics",
    "quick-fix",
    "typescript"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:lopper.refreshWorkspace",
    "onCommand:lopper.refreshWorkspace.force",
    "onCommand:lopper.refreshWorkspace.runtime",
    "onCommand:lopper.refreshWorkspace.package",
    "onCommand:lopper.refreshWorkspace.repo",
    "onCommand:lopper.refreshWorkspace.changedPackages",
    "onCommand:lopper.saveBaseline",
    "onCommand:lopper.compareBaseline",
    "onCommand:lopper.analyseDependency",
    "onCommand:lopper.exportAnalysis.json",
    "onCommand:lopper.exportAnalysis.csv",
    "onCommand:lopper.exportAnalysis.sarif",
    "onCommand:lopper.exportAnalysis.prComment",
    "onCommand:lopper.openLocation",
    "onView:lopperExplorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lopper.refreshWorkspace",
        "title": "Lopper: Refresh Diagnostics"
      },
      {
        "command": "lopper.refreshWorkspace.force",
        "title": "Lopper: Refresh Diagnostics (Force Fresh)"
      },
      {
        "command": "lopper.refreshWorkspace.runtime",
        "title": "Lopper: Refresh Diagnostics (Runtime Trace)"
      },
      {
        "command": "lopper.refreshWorkspace.package",
        "title": "Lopper: Refresh Diagnostics (Scope: package)"
      },
      {
        "command": "lopper.refreshWorkspace.repo",
        "title": "Lopper: Refresh Diagnostics (Scope: repo)"
      },
      {
        "command": "lopper.refreshWorkspace.changedPackages",
        "title": "Lopper: Refresh Diagnostics (Scope: changed-packages)"
      },
      {
        "command": "lopper.saveBaseline",
        "title": "Lopper: Save Baseline Snapshot"
      },
      {
        "command": "lopper.compareBaseline",
        "title": "Lopper: Compare Baseline"
      },
      {
        "command": "lopper.analyseDependency",
        "title": "Lopper: Analyse Dependency..."
      },
      {
        "command": "lopper.exportAnalysis.json",
        "title": "Lopper: Export Analysis as JSON"
      },
      {
        "command": "lopper.exportAnalysis.csv",
        "title": "Lopper: Export Analysis as CSV"
      },
      {
        "command": "lopper.exportAnalysis.sarif",
        "title": "Lopper: Export Analysis as SARIF"
      },
      {
        "command": "lopper.exportAnalysis.prComment",
        "title": "Lopper: Export Analysis as PR Comment"
      },
      {
        "command": "lopper.openLocation",
        "title": "Lopper: Open Location"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "lopperExplorer",
          "name": "Lopper",
          "contextualTitle": "Lopper"
        }
      ]
    },
    "configuration": {
      "title": "Lopper",
      "properties": {
        "lopper.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "all",
            "cpp",
            "dart",
            "dotnet",
            "elixir",
            "go",
            "js-ts",
            "jvm",
            "kotlin-android",
            "php",
            "powershell",
            "python",
            "ruby",
            "rust",
            "swift"
          ],
          "enumDescriptions": [
            "Infer the adapter from the active or saved editor when possible, including Android Gradle Kotlin/Java modules, then fall back to lopper's CLI auto detection.",
            "Run every matching Lopper adapter in the workspace and merge the results.",
            "Use the C/C++ adapter.",
            "Use the Dart adapter.",
            "Use the .NET adapter.",
            "Use the Elixir adapter.",
            "Use the Go adapter.",
            "Use the JavaScript and TypeScript adapter.",
            "Use the JVM adapter.",
            "Use the Kotlin Android adapter.",
            "Use the PHP adapter.",
            "Use the PowerShell adapter (preview-gated by powershell-adapter-preview).",
            "Use the Python adapter.",
            "Use the Ruby adapter.",
            "Use the Rust adapter.",
            "Use the Swift adapter."
          ],
          "markdownDescription": "Language adapter mode for workspace analysis. `auto` is the default and is editor-aware, including Android Gradle Kotlin/Java modules; `all` merges every matching adapter."
        },
        "lopper.scopeMode": {
          "type": "string",
          "default": "package",
          "enum": [
            "package",
            "repo",
            "changed-packages"
          ],
          "enumDescriptions": [
            "Analyze the package or module context currently active in the workspace.",
            "Analyze the full repository surface.",
            "Analyze only packages changed in the current branch or workspace diff."
          ],
          "markdownDescription": "Analysis scope mode passed to the lopper CLI with `--scope-mode`."
        },
        "lopper.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a lopper binary. Relative paths are resolved from the workspace root."
        },
        "lopper.topN": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Maximum number of dependencies to analyse per refresh."
        },
        "lopper.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Refresh diagnostics when a saved file matches the selected adapter mode."
        },
        "lopper.autoDownloadBinary": {
          "type": "boolean",
          "default": true,
          "description": "Automatically download a matching lopper release into extension-managed storage when no local binary is available."
        },
        "lopper.managedBinaryTag": {
          "type": "string",
          "default": "",
          "description": "Optional lopper release tag to download for managed installs. Leave empty to use the latest GitHub release."
        },
        "lopper.runtimeTracePath": {
          "type": "string",
          "default": "",
          "description": "Optional runtime trace file to use for JS/TS runtime-aware analysis."
        },
        "lopper.runtimeTestCommand": {
          "type": "string",
          "default": "",
          "description": "Optional command to run while capturing a runtime trace for JS/TS analysis."
        },
        "lopper.thresholdFailOnIncreasePercent": {
          "type": "number",
          "default": -1,
          "minimum": -1,
          "description": "Fail when waste increases by more than this percentage. Use -1 to disable the gate."
        },
        "lopper.thresholdLowConfidenceWarningPercent": {
          "type": "number",
          "default": 40,
          "minimum": 0,
          "maximum": 100,
          "description": "Warn when dependency confidence falls below this percentage."
        },
        "lopper.thresholdMinUsagePercentForRecommendations": {
          "type": "number",
          "default": 40,
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum usage percentage required before recommendation generation is suppressed."
        },
        "lopper.thresholdMaxUncertainImportCount": {
          "type": "number",
          "default": -1,
          "minimum": -1,
          "description": "Fail when uncertain dynamic imports or requires exceed this count. Use -1 to disable the gate."
        },
        "lopper.licenseDeny": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "SPDX identifiers to deny during analysis."
        },
        "lopper.licenseFailOnDeny": {
          "type": "boolean",
          "default": false,
          "description": "Fail when denied licenses are detected."
        },
        "lopper.licenseProvenanceRegistry": {
          "type": "boolean",
          "default": false,
          "description": "Enable registry provenance heuristics for JS/TS dependencies."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest:e2e": "npm run compile",
    "test:e2e": "node ./src/test/runTest.mjs",
    "package:vsix": "vsce package"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.3.0",
    "@types/adm-zip": "^0.5.7",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^13.0.0",
    "mocha": "^11.7.2",
    "typescript": "^6.0.0"
  }
}
